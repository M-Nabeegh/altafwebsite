# ─────────────────────────────────────────────────────────────────────────────
# javedaltaf.com — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── PayFast Configuration ─────────────────────────────────────────────────────
# Set to UAT for testing, LIVE for production
PAYFAST_ENV=LIVE

# Live credentials — provided by PayFast portal (never expose in frontend)
PAYFAST_MERCHANT_ID=your_merchant_id_here
PAYFAST_SECURED_KEY=your_secured_key_here
PAYFAST_MERCHANT_NAME=Prof. Dr. Javed Altaf

# Consultation amount in PKR (integer)
# Set to 10 for initial testing, change to 4000 for production
CONSULTATION_AMOUNT=10

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── VeevoTech SMS (server-side only) ──────────────────────────────────────────
VEEVOTECH_API_HASH=your_veevotech_api_hash_here
VEEVOTECH_SENDER_ID=Default

# ── Resend Email Service ───────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# From address (must be a verified domain in Resend)
EMAIL_FROM=appointments@javedaltaf.com

# Doctor/admin email to receive booking notifications
DOCTOR_EMAIL=javed_altafdr@yahoo.com

# ── Site URL ──────────────────────────────────────────────────────────────────
# Used to build SUCCESS_URL, FAILURE_URL, CHECKOUT_URL
VITE_SITE_BASE_URL=https://javedaltaf.com

# ── Admin Dashboard ───────────────────────────────────────────────────────────
# Password required to access the /admin dashboard
ADMIN_PASSWORD=your_secure_password_here
